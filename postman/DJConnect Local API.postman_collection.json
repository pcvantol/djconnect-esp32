    {
      "name": "Destructive Web Actions",
      "item": [
        {
          "name": "Reset HA Pairing From Web",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{base_url}}/api/reset-pairing",
            "description": "Destructive local web action. Clears Home Assistant pairing and restarts into pairing mode."
          },
          "response": []
        },
        {
          "name": "Reboot From Web",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{base_url}}/api/reboot",
            "description": "Local web action. Restarts the device."
          },
          "response": []
        },
        {
          "name": "Factory Reset From Web",
          "request": {
            "method": "POST",
