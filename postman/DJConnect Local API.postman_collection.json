            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "action",
                  "value": "pause",
                  "type": "text"
                }
              ]
            },
            "url": "{{base_url}}/api/playback",
            "description": "Same local action as the web portal pause button."
          },
          "response": []
        },
        {
          "name": "Playback Next",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
