{
  "info": {
    "_postman_id": "c3a93b1f-0cf4-4b90-8b2a-djconnect-local-api",
    "name": "DJConnect Local API",
    "description": "Local ESP web portal and device API for a DJConnect device. Set base_url to the device IP or mDNS URL, for example http://djconnect-lilygo-t-embed-s3-XXXXXXXXXXXX.local. Web portal routes use form-urlencoded bodies and generally do not require auth. Device-layer routes under /api/device require Authorization: Bearer {{device_token}} except info and pairing-info.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "noauth"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://djconnect-lilygo-t-embed-s3-XXXXXXXXXXXX.local",
      "type": "string"
    },
    {
      "key": "device_token",
      "value": "",
      "type": "secret"
    },
    {
      "key": "device_id",
      "value": "djconnect-lilygo-t-embed-s3-XXXXXXXXXXXX",
      "type": "string"
    },
    {
      "key": "pair_code",
      "value": "123456",
      "type": "string"
    },
    {
      "key": "ha_local_url",
      "value": "http://homeassistant.local:8123",
      "type": "string"
    },
    {
      "key": "firmware_version",
      "value": "3.1.16",
      "type": "string"
    },
    {
      "key": "device_model",
      "value": "lilygo-t-embed-s3",
      "type": "string"
    },
    {
      "key": "firmware_url",
      "value": "https://github.com/pcvantol/djconnect-firmware/releases/download/v{{firmware_version}}/djconnect-lilygo-t-embed-s3-v{{firmware_version}}.bin",
      "type": "string"
    },
    {
      "key": "firmware_sha256",
      "value": "",
      "type": "string"
    },
    {
      "key": "playlist_uri",
      "value": "spotify:playlist:example",
      "type": "string"
    },
    {
      "key": "queue_item_uri",
      "value": "spotify:track:example",
      "type": "string"
    },
    {
      "key": "output_name",
      "value": "iPhone",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Open / Diagnostics",
      "item": [
        {
          "name": "Web Portal",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/",
            "description": "Loads the local mobile web portal."
          },
          "response": []
        },
        {
          "name": "Web Status JSON",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/status",
            "description": "Returns the live web portal status snapshot: app/device model, firmware, HA pairing, playback, WiFi, battery, settings and game-independent UI state."
          },
          "response": []
        },
        {
          "name": "Logs Text",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/logs",
            "description": "Returns the in-memory device log as text."
          },
          "response": []
        },
        {
          "name": "Playback Devices JSON",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/devices",
            "description": "Returns playback outputs known through Home Assistant. Returns an unavailable payload when playback is not connected."
          },
          "response": []
        },
        {
          "name": "Playlists JSON",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/playlists",
            "description": "Returns playlists from the Home Assistant playback backend."
          },
          "response": []
        },
        {
          "name": "Queue JSON",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/queue",
            "description": "Returns Up Next queue items, including title, subtitle, URI and optional imageUrl."
          },
          "response": []
        },
        {
          "name": "Device Info",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/device/info",
            "description": "Open device-layer identity/status endpoint: device_id, device model, firmware, pairing state, local URL and runtime state."
          },
          "response": []
        },
        {
          "name": "Pairing Info",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/device/pairing-info",
            "description": "Open pairing endpoint with pair_code, device_id, client_type esp32, firmware and mDNS local_url."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Web Portal Playback",
      "item": [
        {
          "name": "Playback Play",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "action",
                  "value": "play",
                  "type": "text"
                }
              ]
            },
            "url": "{{base_url}}/api/playback",
            "description": "Same local action as the web portal play button."
          },
          "response": []
        },
        {
          "name": "Playback Pause",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
