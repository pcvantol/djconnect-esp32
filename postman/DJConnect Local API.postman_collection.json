                  "key": "password",
                  "value": "",
                  "type": "text"
                }
              ]
            },
            "url": "{{base_url}}/api/wifi",
            "description": "Starts a WiFi credential test. Keep password empty in committed collections; set it only in your local Postman environment."
          },
          "response": []
        },
        {
          "name": "Web Voice Text Test",
          "request": {
            "method": "POST",
            "header": [
