              ]
            },
            "url": "{{base_url}}/api/voice-text",
            "description": "Runs the web portal fixed-text DJ announcement flow through ESP -> HA /api/djconnect/voice. It intentionally does not play returned TTS audio."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Device Layer Pairing",
      "item": [
        {
          "name": "Pair Device",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pair_code\": \"{{pair_code}}\",\n  \"device_id\": \"{{device_id}}\",\n  \"device_name\": \"DJConnect\",\n  \"client_type\": \"esp32\",\n  \"device_token\": \"{{device_token}}\",\n  \"ha_local_url\": \"{{ha_local_url}}\",\n  \"device_language\": \"nl\",\n  \"language\": \"nl\"\n}"
            },
            "url": "{{base_url}}/api/device/pair",
            "description": "Home Assistant direct pairing callback. The ESP accepts only its own model-specific device_id, client_type esp32 and a real LAN ha_local_url."
          },
          "response": []
        },
        {
          "name": "Forget Pairing",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{device_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "url": "{{base_url}}/api/device/forget",
            "description": "Protected endpoint. Clears Home Assistant pairing and restarts into pairing mode."
          },
          "response": []
        }
      ]
    },
