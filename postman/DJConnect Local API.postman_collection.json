            "url": "{{base_url}}/api/device/dj_response",
            "description": "Protected endpoint used by Home Assistant to show and optionally play a DJ announcement. audio_url may point to WAV or MP3."
          },
          "response": []
        },
        {
          "name": "Start OTA",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{device_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"{{firmware_url}}\",\n  \"sha256\": \"{{firmware_sha256}}\",\n  \"version\": \"{{firmware_version}}\",\n  \"device\": \"{{device_model}}\"\n}"
            },
            "url": "{{base_url}}/api/device/ota",
            "description": "Protected OTA endpoint. The device field must match the active board profile, for example lilygo-t-embed-s3 or esp32-s3-box-3."
          },
          "response": []
        },
        {
          "name": "Reboot Device",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{device_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "url": "{{base_url}}/api/device/reboot",
            "description": "Protected endpoint. Returns success, then restarts after a short delay."
          },
          "response": []
        }
