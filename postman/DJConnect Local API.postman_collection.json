                }
              ]
            },
            "url": "{{base_url}}/api/playback",
            "description": "Same local action as the web portal next button."
          },
          "response": []
        },
        {
          "name": "Playback Previous",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "action",
                  "value": "previous",
                  "type": "text"
                }
              ]
            },
            "url": "{{base_url}}/api/playback",
            "description": "Same local action as the web portal previous button."
          },
          "response": []
        },
        {
          "name": "Start Default Playlist",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "action",
                  "value": "likedProxy",
                  "type": "text"
                }
              ]
            },
            "url": "{{base_url}}/api/playback",
            "description": "Starts the configured default playlist through Home Assistant."
          },
          "response": []
        },
        {
          "name": "Start Playlist URI",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "action",
                  "value": "playlist",
                  "type": "text"
                },
                {
                  "key": "uri",
                  "value": "{{playlist_uri}}",
                  "type": "text"
                }
              ]
            },
            "url": "{{base_url}}/api/playback",
            "description": "Starts a playlist URI through the Home Assistant playback backend."
          },
          "response": []
        },
        {
          "name": "Play Queue Item",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "action",
                  "value": "queue_item",
                  "type": "text"
                },
                {
                  "key": "uri",
                  "value": "{{queue_item_uri}}",
                  "type": "text"
                }
              ]
            },
            "url": "{{base_url}}/api/playback",
            "description": "Starts the selected queue item using the current queue/context URI. Mirrors the Up Next play button."
          },
          "response": []
        },
        {
          "name": "Set Volume",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "volume",
                  "value": "35",
                  "type": "text"
                }
              ]
            },
            "url": "{{base_url}}/api/volume",
            "description": "Queues a playback volume change. User-facing range is 0-60."
          },
          "response": []
        },
        {
          "name": "Set Shuffle",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "enabled",
                  "value": "true",
                  "type": "text"
                }
              ]
            },
            "url": "{{base_url}}/api/shuffle",
            "description": "Sets regular shuffle on/off."
          },
          "response": []
        },
        {
          "name": "Set Repeat",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "repeat",
                  "value": "off",
                  "type": "text"
                }
              ]
            },
            "url": "{{base_url}}/api/repeat",
            "description": "Sets repeat mode: off, track or context."
          },
          "response": []
        },
        {
          "name": "Transfer Output",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "deviceId",
                  "value": "{{output_name}}",
                  "type": "text"
                }
              ]
            },
            "url": "{{base_url}}/api/transfer",
            "description": "Transfers playback to a named output/id. Use none to stop output."
          },
          "response": []
        },
        {
          "name": "Refresh Playback / Queue",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{base_url}}/api/refresh",
            "description": "Requests a local refresh of playback, devices, playlists and queue state."
          },
          "response": []
        }
      ]
    },
