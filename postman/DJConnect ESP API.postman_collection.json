    {
      "name": "Firmware",
      "item": [
        {
          "name": "Start OTA Firmware Update",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{device_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"{{firmware_url}}\",\n  \"sha256\": \"{{firmware_sha256}}\",\n  \"version\": \"3.0.24\",\n  \"device\": \"lilygo-t-embed-s3\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/device/ota",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "device",
                "ota"
              ]
            },
            "description": "Starts OTA firmware update after bearer validation and battery/charging checks. Use the firmware URL that matches the active device model: lilygo-t-embed-s3 or esp32-s3-box-3. The ESP responds before rebooting."
          },
          "response": []
        },
