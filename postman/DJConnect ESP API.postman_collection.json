{
  "info": {
    "_postman_id": "1bfe1a4a-bf33-4a86-9dc5-djconnect-esp-api",
    "name": "DJConnect ESP API",
    "description": "Public/local ESP API for a DJConnect device. Import this collection into Postman and set base_url to the device IP or mDNS URL, for example http://djconnect-lilygo-XXXXXXXXXXXX.local. Protected endpoints require device_token from Home Assistant pairing.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://djconnect-lilygo-XXXXXXXXXXXX.local",
      "type": "string"
    },
    {
      "key": "device_token",
      "value": "",
      "type": "secret"
    },
    {
      "key": "ha_local_url",
      "value": "http://homeassistant.local:8123",
      "type": "string"
    },
    {
      "key": "ha_remote_url",
      "value": "https://example.ui.nabu.casa",
      "type": "string"
    },
    {
      "key": "firmware_url",
      "value": "https://github.com/pcvantol/djconnect-firmware/releases/download/v3.0.24/djconnect-lilygo-t-embed-s3-v3.0.24.bin",
      "type": "string"
    },
    {
      "key": "firmware_sha256",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "noauth"
  },
  "item": [
    {
      "name": "Open",
      "item": [
        {
          "name": "Device Info",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/device/info",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "device",
                "info"
              ]
            },
            "description": "Returns device identity, firmware, model, pairing state, playback config state, battery, WiFi RSSI, active/local/remote HA URLs and last DJ text. No bearer token required."
          },
          "response": []
        },
        {
          "name": "Pairing Info",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/device/pairing-info",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "device",
                "pairing-info"
              ]
            },
            "description": "Returns the current pairing code and local URL. No bearer token required."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Pairing",
      "item": [
        {
          "name": "Pair With Home Assistant",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pair_code\": \"123456\",\n  \"device_id\": \"djconnect-lilygo-XXXXXXXXXXXX\",\n  \"device_name\": \"DJConnect\",\n  \"client_type\": \"esp32\",\n  \"device_token\": \"{{device_token}}\",\n  \"ha_local_url\": \"{{ha_local_url}}\",\n  \"ha_remote_url\": \"{{ha_remote_url}}\",\n  \"device_language\": \"nl\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/device/pair",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "device",
                "pair"
              ]
            },
            "description": "Direct Home Assistant pairing callback. Stores the device token plus local/cloud HA URLs on the ESP. The device_id must match the LilyGO device and client_type must be esp32."
          },
          "response": []
        },
        {
          "name": "Forget Pairing",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{device_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/device/forget",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "device",
                "forget"
              ]
            },
            "description": "Clears HA pairing, updates mDNS TXT records, then restarts into pairing mode."
          },
          "response": []
        }
      ]
    },
    {
      "name": "DJ Response",
      "item": [
        {
          "name": "Display DJ Response Text",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{device_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Daar gaan we. DJConnect is klaar voor je volgende plaat.\",\n  \"audio_url\": \"\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/device/dj_response",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "device",
                "dj_response"
              ]
            },
            "description": "Pushes a DJ response to the ESP display. If audio_url points to a compatible PCM WAV, the ESP attempts speaker playback."
          },
          "response": []
        }
      ]
    },
